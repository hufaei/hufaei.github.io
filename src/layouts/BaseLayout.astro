---
import "../styles/global.css";
import ControlBar from "../components/ControlBar.astro";
import LocalizedText from "../components/LocalizedText.astro";
import { siteCopy } from "../data/siteCopy";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = siteCopy.title.zh,
  description = "Mirune is a static anime watch archive."
} = Astro.props;
const footerCopy = {
  zh: "番剧、电影和系列，按进度、系列与公开评分归档。",
  ja: "アニメ、映画、シリーズを進捗・シリーズ・公開評価で記録。",
  en: "Anime, films, and series archived by progress, series, and public ratings."
};
---

<!doctype html>
<html lang="zh" data-theme="dark" data-language="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      const theme = localStorage.getItem("theme") || "dark";
      const language = localStorage.getItem("language") || "zh";
      document.documentElement.dataset.theme = theme;
      document.documentElement.dataset.language = language;
      document.documentElement.lang = language;
    </script>
  </head>
  <body>
    <div class="site-shell">
      <ControlBar />
      <slot />
      <footer class="footer">
        <LocalizedText text={footerCopy} />
      </footer>
    </div>
  </body>
</html>
