---
import "../styles/global.css";
import ControlBar from "../components/ControlBar.astro";
import { siteCopy } from "../data/siteCopy";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = siteCopy.title.zh,
  description = "A static anime watch archive for hufaei."
} = Astro.props;
---

<!doctype html>
<html lang="zh" data-theme="dark" data-language="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      const theme = localStorage.getItem("theme") || "dark";
      const language = localStorage.getItem("language") || "zh";
      document.documentElement.dataset.theme = theme;
      document.documentElement.dataset.language = language;
      document.documentElement.lang = language;
    </script>
  </head>
  <body>
    <div class="site-shell">
      <ControlBar />
      <slot />
      <footer class="footer">
        Mock archive demo. Metadata is static demo data; no runtime API requests.
      </footer>
    </div>
  </body>
</html>
