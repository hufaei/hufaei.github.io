---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { animeEntries, seriesEntries } from "../../data/mockArchive";
import { buildSearchIndex } from "../../lib/search";

const index = buildSearchIndex({ anime: animeEntries, series: seriesEntries });
---

<BaseLayout title="搜索">
  <main class="page">
    <section class="section">
      <h1 class="page-title">检索</h1>
    </section>
    <section class="section">
      <input class="search-box" type="search" placeholder="输入番名、别名、标签或状态..." data-search-input />
    </section>
    <section class="section">
      <div class="grid" data-search-results>
        {index.map((item) => (
          <a class="card" style="padding:16px" href={item.type === "anime" ? `/anime/${item.slug}/` : `/series/${item.slug}/`} data-search-item={item.haystack}>
            <div class="card-kicker">{item.type}</div>
            <h3>{item.title}</h3>
          </a>
        ))}
      </div>
    </section>
  </main>

  <script>
    const input = document.querySelector("[data-search-input]");
    const items = [...document.querySelectorAll("[data-search-item]")];
    function applySearchFilter() {
      const query = (input as HTMLInputElement).value.trim().toLowerCase();
      for (const item of items) {
        const haystack = item.getAttribute("data-search-item") ?? "";
        item.toggleAttribute("hidden", Boolean(query && !haystack.includes(query)));
      }
    }
    input?.addEventListener("input", applySearchFilter);
    if (input) applySearchFilter();
  </script>
</BaseLayout>
