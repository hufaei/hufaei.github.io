---
import AnimeCard from "../../components/AnimeCard.astro";
import ArchivePagination from "../../components/ArchivePagination.astro";
import LocalizedText from "../../components/LocalizedText.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { animeEntries } from "../../data/mockArchive";
import { siteCopy } from "../../data/siteCopy";
import { paginateItems } from "../../lib/pagination";

const pageTitle = {
  zh: "番剧档案",
  ja: "アニメアーカイブ",
  en: "Anime archive"
};
const pageSize = 24;
const pageData = paginateItems(animeEntries, 1, pageSize);
const pageSummary = {
  zh: `${pageData.totalItems} 部作品 · 第 ${pageData.currentPage} / ${pageData.totalPages} 页`,
  ja: `${pageData.totalItems}作品 · ${pageData.currentPage} / ${pageData.totalPages}ページ`,
  en: `${pageData.totalItems} works · page ${pageData.currentPage} of ${pageData.totalPages}`
};
---

<BaseLayout title={`${pageTitle.zh} - ${siteCopy.title.zh}`}>
  <main class="page">
    <section class="section">
      <div class="section-head listing-head">
        <h1 class="page-title"><LocalizedText text={pageTitle} /></h1>
        <span class="section-note" data-list-summary><LocalizedText text={pageSummary} /></span>
      </div>
    </section>

    <section class="section archive-tools">
      <input class="search-box" type="search" placeholder="搜索标题、别名、标签..." data-i18n-placeholder="archiveSearchPlaceholder" data-filter-input />
      <div class="segmented archive-sort" aria-label="排序">
        <button type="button" data-sort-key="default" aria-pressed="true" data-i18n="sortDefault">默认</button>
        <button type="button" data-sort-key="score-desc" aria-pressed="false" data-i18n="sortScore">评分</button>
        <button type="button" data-sort-key="rank-asc" aria-pressed="false" data-i18n="sortRank">排名</button>
        <button type="button" data-sort-key="year-desc" aria-pressed="false" data-i18n="sortYear">年份</button>
        <button type="button" data-sort-key="title-asc" aria-pressed="false" data-i18n="sortTitle">标题</button>
      </div>
    </section>

    <section class="section">
      <div class="grid cards" data-archive-grid data-page-size={pageSize}>
        {animeEntries.map((entry, index) => <AnimeCard entry={entry} entryIndex={index} initiallyHidden={index >= pageSize} />)}
      </div>
      <div data-static-pagination>
        <ArchivePagination basePath="/anime/" currentPage={pageData.currentPage} totalPages={pageData.totalPages} />
      </div>
      <nav class="pagination" data-client-pagination aria-label="Archive pagination" hidden></nav>
    </section>
  </main>

  <script>
    import { mountAnimeArchiveControls } from "../../lib/animeArchiveControls";

    mountAnimeArchiveControls();
  </script>
</BaseLayout>
