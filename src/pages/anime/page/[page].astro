---
import AnimeCard from "../../../components/AnimeCard.astro";
import ArchivePagination from "../../../components/ArchivePagination.astro";
import LocalizedText from "../../../components/LocalizedText.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { animeEntries } from "../../../data/mockArchive";
import { siteCopy } from "../../../data/siteCopy";
import { paginateItems } from "../../../lib/pagination";

const pageTitle = {
  zh: "番剧档案",
  ja: "アニメアーカイブ",
  en: "Anime archive"
};

export function getStaticPaths() {
  const firstPage = paginateItems(animeEntries, 1, 24);

  return Array.from({ length: firstPage.totalPages - 1 }, (_, index) => {
    const currentPage = index + 2;
    return {
      params: { page: String(currentPage) },
      props: { pageData: paginateItems(animeEntries, currentPage, 24) }
    };
  });
}

const { pageData } = Astro.props;
const pageSummary = {
  zh: `${pageData.totalItems} 部作品 · 第 ${pageData.currentPage} / ${pageData.totalPages} 页`,
  ja: `${pageData.totalItems}作品 · ${pageData.currentPage} / ${pageData.totalPages}ページ`,
  en: `${pageData.totalItems} works · page ${pageData.currentPage} of ${pageData.totalPages}`
};
---

<BaseLayout title={`${pageTitle.zh} ${pageData.currentPage} - ${siteCopy.title.zh}`}>
  <main class="page">
    <section class="section">
      <div class="section-head listing-head">
        <h1 class="page-title"><LocalizedText text={pageTitle} /></h1>
        <span class="section-note"><LocalizedText text={pageSummary} /></span>
      </div>
    </section>

    <section class="section">
      <input class="search-box" type="search" placeholder="搜索本页标题、别名、标签..." data-i18n-placeholder="archiveSearchPlaceholder" data-filter-input />
    </section>

    <section class="section">
      <div class="grid cards">
        {pageData.items.map((entry) => <AnimeCard entry={entry} />)}
      </div>
      <ArchivePagination basePath="/anime/" currentPage={pageData.currentPage} totalPages={pageData.totalPages} />
    </section>
  </main>

  <script>
    const input = document.querySelector("[data-filter-input]");
    const cards = [...document.querySelectorAll("[data-search-card]")];
    function applyArchiveFilter() {
      const query = (input as HTMLInputElement).value.trim().toLowerCase();
      for (const card of cards) {
        const haystack = card.getAttribute("data-title")?.toLowerCase() ?? "";
        card.toggleAttribute("hidden", Boolean(query && !haystack.includes(query)));
      }
    }
    input?.addEventListener("input", applyArchiveFilter);
    if (input) applyArchiveFilter();
  </script>
</BaseLayout>
