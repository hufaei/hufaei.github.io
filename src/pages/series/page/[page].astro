---
import LocalizedText from "../../../components/LocalizedText.astro";
import ArchivePagination from "../../../components/ArchivePagination.astro";
import SeriesCard from "../../../components/SeriesCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getSeriesEntries, seriesEntries } from "../../../data/mockArchive";
import { siteCopy } from "../../../data/siteCopy";
import { paginateItems } from "../../../lib/pagination";

const pageTitle = {
  zh: "系列总览",
  ja: "シリーズ一覧",
  en: "Series index"
};

export function getStaticPaths() {
  const firstPage = paginateItems(seriesEntries, 1, 24);

  return Array.from({ length: firstPage.totalPages - 1 }, (_, index) => {
    const currentPage = index + 2;
    return {
      params: { page: String(currentPage) },
      props: { pageData: paginateItems(seriesEntries, currentPage, 24) }
    };
  });
}

const { pageData } = Astro.props;
const pageSummary = {
  zh: `${pageData.totalItems} 个系列 · 第 ${pageData.currentPage} / ${pageData.totalPages} 页`,
  ja: `${pageData.totalItems}シリーズ · ${pageData.currentPage} / ${pageData.totalPages}ページ`,
  en: `${pageData.totalItems} series · page ${pageData.currentPage} of ${pageData.totalPages}`
};
---

<BaseLayout title={`${pageTitle.zh} ${pageData.currentPage} - ${siteCopy.title.zh}`}>
  <main class="page">
    <section class="section">
      <div class="section-head listing-head">
        <h1 class="page-title"><LocalizedText text={pageTitle} /></h1>
        <span class="section-note"><LocalizedText text={pageSummary} /></span>
      </div>
    </section>

    <section class="section">
      <input class="search-box" type="search" placeholder="搜索本页系列、番名、年份或标签..." data-i18n-placeholder="seriesSearchPlaceholder" data-series-filter-input />
    </section>

    <section class="section">
      <div class="grid cards">
        {pageData.items.map((series) => <SeriesCard series={series} entries={getSeriesEntries(series)} />)}
      </div>
      <ArchivePagination basePath="/series/" currentPage={pageData.currentPage} totalPages={pageData.totalPages} />
    </section>
  </main>

  <script>
    const input = document.querySelector("[data-series-filter-input]");
    const cards = [...document.querySelectorAll("[data-series-card]")];
    function applySeriesFilter() {
      const query = (input as HTMLInputElement).value.trim().toLowerCase();
      for (const card of cards) {
        const haystack = card.getAttribute("data-title")?.toLowerCase() ?? "";
        card.toggleAttribute("hidden", Boolean(query && !haystack.includes(query)));
      }
    }
    input?.addEventListener("input", applySeriesFilter);
    if (input) applySeriesFilter();
  </script>
</BaseLayout>
