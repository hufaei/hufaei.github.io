---
import LocalizedText from "../../components/LocalizedText.astro";
import SeriesCard from "../../components/SeriesCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSeriesEntries, seriesEntries } from "../../data/mockArchive";
import { siteCopy } from "../../data/siteCopy";

const pageTitle = {
  zh: "系列总览",
  ja: "シリーズ一覧",
  en: "Series index"
};
const seriesCount = {
  zh: `${seriesEntries.length} 个系列`,
  ja: `${seriesEntries.length}シリーズ`,
  en: `${seriesEntries.length} series`
};
---

<BaseLayout title={`${pageTitle.zh} - ${siteCopy.title.zh}`}>
  <main class="page">
    <section class="section">
      <div class="section-head">
        <h1 class="page-title"><LocalizedText text={pageTitle} /></h1>
        <span class="section-note"><LocalizedText text={seriesCount} /></span>
      </div>
    </section>

    <section class="section">
      <input class="search-box" type="search" placeholder="搜索番名、别名、系列、年份或标签..." data-i18n-placeholder="searchPlaceholder" data-series-filter-input />
    </section>

    <section class="section">
      <div class="grid cards">
        {seriesEntries.map((series) => <SeriesCard series={series} entries={getSeriesEntries(series)} />)}
      </div>
    </section>
  </main>

  <script>
    const input = document.querySelector("[data-series-filter-input]");
    const cards = [...document.querySelectorAll("[data-series-card]")];
    function applySeriesFilter() {
      const query = (input as HTMLInputElement).value.trim().toLowerCase();
      for (const card of cards) {
        const haystack = card.getAttribute("data-title")?.toLowerCase() ?? "";
        card.toggleAttribute("hidden", Boolean(query && !haystack.includes(query)));
      }
    }
    input?.addEventListener("input", applySeriesFilter);
    if (input) applySeriesFilter();
  </script>
</BaseLayout>
