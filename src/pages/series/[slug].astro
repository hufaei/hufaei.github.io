---
import AnimeCard from "../../components/AnimeCard.astro";
import LocalizedText from "../../components/LocalizedText.astro";
import ProgressBar from "../../components/ProgressBar.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSeriesEntries, seriesEntries } from "../../data/mockArchive";
import { siteCopy } from "../../data/siteCopy";
import { localizedCopy } from "../../i18n/dictionary";
import { localizePlatform } from "../../i18n/localizedTag";
import { calculateSeriesProgress } from "../../lib/progress";

export function getStaticPaths() {
  return seriesEntries.map((series) => ({
    params: { slug: series.slug },
    props: { series, entries: getSeriesEntries(series) }
  }));
}

const { series, entries } = Astro.props;
const progress = calculateSeriesProgress(entries);
const years = entries.map((entry) => entry.year).filter((year): year is number => Boolean(year));
const yearRange = years.length ? `${Math.min(...years)}-${Math.max(...years)}` : "年份待补";
const yearRangeText = years.length
  ? { zh: yearRange, ja: yearRange, en: yearRange }
  : localizedCopy("yearPending");
const entryCount = {
  zh: `${entries.length} 个条目`,
  ja: `${entries.length}件`,
  en: `${entries.length} entries`
};
const heroMeta = {
  zh: `${yearRangeText.zh} / ${entryCount.zh} / 季、剧场版、OVA`,
  ja: `${yearRangeText.ja} / ${entryCount.ja} / シーズン・劇場版・OVA`,
  en: `${yearRangeText.en} / ${entryCount.en} / seasons, movies, OVA`
};
const heroDescription = {
  zh: "这个系列由原始列表拆分后整理成多个子条目。每一季、剧场版、OVA 或外传都可以继续进入详情页查看简介、年份、封面和公开评分。",
  ja: "このシリーズは元の視聴リストを分割して整理したものです。各シーズン、劇場版、OVA、外伝から詳細ページへ進めます。",
  en: "This series is split from the original watch list into child entries. Each season, movie, OVA, or spin-off links to its own detail page."
};
---

<BaseLayout title={`${series.title.zh} - ${siteCopy.title.zh}`}>
  <main class="page">
    <section class="hero">
      <picture class="hero-visual">
        <img src={series.banner} alt="" loading="eager" />
      </picture>
      <div class="hero-content">
        <div class="eyebrow"><LocalizedText text={heroMeta} /></div>
        <h1><LocalizedText text={series.title} /></h1>
        <p><LocalizedText text={heroDescription} /></p>
        <ProgressBar percent={progress.percent} watched={progress.watched} total={progress.total} />
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <h2><LocalizedText text={localizedCopy("seriesComposition")} /></h2>
        <span class="section-note"><LocalizedText text={yearRangeText} /></span>
      </div>
      <div class="series-list">
        {entries.map((entry) => (
          <a class="series-row" href={`/anime/${entry.slug}/`}>
            <img src={entry.cover} alt="" loading="lazy" />
            <div>
              <div class="card-kicker">
                <span>{entry.year ?? <LocalizedText text={localizedCopy("yearPending")} />}</span>
                <span><LocalizedText text={localizePlatform(entry.platform)} /></span>
                <span>
                  {entry.totalEpisodes
                    ? (
                        <>
                          {entry.totalEpisodes} <LocalizedText text={localizedCopy("episodes")} />
                        </>
                      )
                    : <LocalizedText text={localizedCopy("episodesPending")} />}
                </span>
              </div>
              <h3><LocalizedText text={entry.title} /></h3>
              <p><LocalizedText text={entry.description} /></p>
            </div>
            <span class="button"><LocalizedText text={localizedCopy("details")} /></span>
          </a>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <h2><LocalizedText text={localizedCopy("seriesEntries")} /></h2>
        <span class="section-note"><LocalizedText text={entryCount} /></span>
      </div>
      <div class="grid">
        {entries.map((entry) => <AnimeCard entry={entry} />)}
      </div>
    </section>
  </main>
</BaseLayout>
