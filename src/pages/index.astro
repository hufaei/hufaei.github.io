---
import AnimeCard from "../components/AnimeCard.astro";
import SeriesCard from "../components/SeriesCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { animeEntries, getSeriesEntries, seriesEntries } from "../data/mockArchive";
import { siteCopy } from "../data/siteCopy";

const featured = animeEntries[0];
const visibleRecords = animeEntries.slice(0, 12);
const visibleSeries = seriesEntries.slice(0, 6);
---

<BaseLayout title={siteCopy.title.zh}>
  <main class="page">
    <section class="hero">
      <picture class="hero-visual">
        <img src={featured.banner} alt="" loading="eager" />
      </picture>
      <div class="hero-content">
        <div class="eyebrow">番剧观看档案 / mock demo / no runtime API</div>
        <h1>{siteCopy.title.zh}</h1>
        <p>
          一个暗色二次元风格的全静态观看档案。这里已经接入你的原始观看列表，详情、封面和公开评分后续再逐步补全。
        </p>
        <div class="hero-actions">
          <a class="button primary" href="/anime/">进入番剧档案</a>
          {visibleSeries[0] && <a class="button" href={`/series/${visibleSeries[0].slug}/`}>查看系列页</a>}
          <a class="button" href="/search/">搜索 demo</a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <h2>观看清单</h2>
        <span class="section-note">{animeEntries.length} records</span>
      </div>
      <div class="grid cards">
        {visibleRecords.map((entry) => <AnimeCard entry={entry} />)}
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <h2>系列索引</h2>
        <span class="section-note">{seriesEntries.length} multi-part records</span>
      </div>
      <div class="grid cards">
        {visibleSeries.map((series) => <SeriesCard series={series} entries={getSeriesEntries(series)} />)}
      </div>
    </section>
  </main>
</BaseLayout>
