---
import AnimeCard from "../components/AnimeCard.astro";
import LocalizedText from "../components/LocalizedText.astro";
import SeriesCard from "../components/SeriesCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { animeEntries, getSeriesEntries, seriesEntries } from "../data/mockArchive";
import { siteCopy } from "../data/siteCopy";
import { localizedCopy } from "../i18n/dictionary";
import { buildSearchIndex } from "../lib/search";

const featured = animeEntries[0];
const visibleRecords = animeEntries.slice(0, 12);
const visibleSeries = seriesEntries.slice(0, 6);
const searchIndex = buildSearchIndex({ anime: animeEntries, series: seriesEntries });
const heroEyebrow = {
  zh: "Mirune = 見るね",
  ja: "ミルネ = 見るね",
  en: "Mirune = miru ne"
};
const heroBody = {
  zh: "「見る」是看，「ね」像句尾轻轻落下的“呢”。Mirune 就是把看过的番、电影和系列慢慢收好，偶尔回头看一眼。",
  ja: "「見る」に、少しやわらかい「ね」を添えて。見たアニメ、映画、シリーズを静かに残して、ふと思い出せる場所。",
  en: "Mirune comes from miru, to watch, with the soft note of ne. A quiet place for anime, films, and series already seen."
};
const searchCount = {
  zh: `${searchIndex.length} 条可检索`,
  ja: `${searchIndex.length}件を検索可能`,
  en: `${searchIndex.length} searchable items`
};
const animeCount = {
  zh: `${animeEntries.length} 部作品`,
  ja: `${animeEntries.length}作品`,
  en: `${animeEntries.length} works`
};
const seriesCount = {
  zh: `${seriesEntries.length} 个系列`,
  ja: `${seriesEntries.length}シリーズ`,
  en: `${seriesEntries.length} series`
};
---

<BaseLayout title={siteCopy.title.zh}>
  <main class="page">
    <section class="hero">
      <picture class="hero-visual">
        <img src={featured.banner} alt="" loading="eager" />
      </picture>
      <div class="hero-content">
        <div class="eyebrow"><LocalizedText text={heroEyebrow} /></div>
        <h1><LocalizedText text={siteCopy.title} /></h1>
        <p><LocalizedText text={heroBody} /></p>
        <div class="hero-actions">
          <a class="button primary" href="/anime/"><LocalizedText text={localizedCopy("openArchive")} /></a>
          <a class="button" href="/series/"><LocalizedText text={localizedCopy("openSeries")} /></a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <h2><LocalizedText text={localizedCopy("search")} /></h2>
        <span class="section-note"><LocalizedText text={searchCount} /></span>
      </div>
      <input class="search-box" type="search" placeholder="搜索番名、别名、系列、年份或标签..." data-i18n-placeholder="searchPlaceholder" data-home-search-input />
      <div class="grid search-results" data-home-search-results>
        {searchIndex.map((item) => (
          <a class="card search-result" href={item.type === "anime" ? `/anime/${item.slug}/` : `/series/${item.slug}/`} data-search-item={item.haystack} hidden>
            <div class="card-kicker">
              <span><LocalizedText text={localizedCopy(item.type)} /></span>
              {item.year && <span>{item.year}</span>}
            </div>
            <h3><LocalizedText text={item.localizedTitle} /></h3>
          </a>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <h2><LocalizedText text={localizedCopy("watchList")} /></h2>
        <span class="section-note"><LocalizedText text={animeCount} /></span>
      </div>
      <div class="grid cards">
        {visibleRecords.map((entry) => <AnimeCard entry={entry} />)}
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <h2><LocalizedText text={localizedCopy("series")} /></h2>
        <span class="section-note"><LocalizedText text={seriesCount} /></span>
      </div>
      <div class="grid cards">
        {visibleSeries.map((series) => <SeriesCard series={series} entries={getSeriesEntries(series)} />)}
      </div>
    </section>
  </main>

  <script>
    const input = document.querySelector("[data-home-search-input]");
    const items = [...document.querySelectorAll("[data-search-item]")];
    function applyHomeSearch() {
      const query = (input as HTMLInputElement).value.trim().toLowerCase();
      for (const item of items) {
        const haystack = item.getAttribute("data-search-item") ?? "";
        item.toggleAttribute("hidden", Boolean(!query || !haystack.includes(query)));
      }
    }
    input?.addEventListener("input", applyHomeSearch);
    if (input) applyHomeSearch();
  </script>
</BaseLayout>
